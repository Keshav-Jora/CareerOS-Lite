# CareerOS Lite — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to version control.
#
# This file mirrors the .env.example committed to the repository.
# The authoritative version is at the repo root.

# ===========================================================
# AI PROVIDERS
# VITE_GEMINI_API_KEY is required. Nova will not function without it.
# All other provider keys are optional.
# ===========================================================

# Google Gemini — required
# Get key: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Groq — optional, for fast inference
# Get key: https://console.groq.com/keys
VITE_GROQ_API_KEY=""

# OpenRouter — optional, accessed via the OpenAI-compatible SDK
# Get key: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=""

# Cerebras — optional
# Get key: https://cloud.cerebras.ai
VITE_CEREBRAS_API_KEY=""

# ===========================================================
# APPLICATION
# ===========================================================

# Set to false to disable all analytics writes.
ENABLE_ANALYTICS=true

# Comma-separated email addresses permitted to access /admin.
VITE_ADMIN_EMAILS="owner@example.com"

# The URL where this app is hosted.
# Used for server-side references, OAuth callbacks, and self-referential links.
# In Google AI Studio this is injected automatically at runtime.
APP_URL="MY_APP_URL"

# ===========================================================
# FIREBASE
# Get these from: Firebase Console → Project Settings → Your apps → Web app
# These are public client identifiers. Protect your data with
# Firebase Auth rules and Firestore security rules.
# ===========================================================

VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
