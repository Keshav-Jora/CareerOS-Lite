# VITE_GEMINI_API_KEY: Required for Nova Gemini API calls.
# Add this key to a local .env file and restart Vite after changing it.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"
VITE_GROQ_API_KEY=""
VITE_OPENROUTER_API_KEY=""
VITE_CEREBRAS_API_KEY=""

# Set to false to disable all product analytics writes.
ENABLE_ANALYTICS=true

# Comma-separated email addresses permitted to open /admin.
VITE_ADMIN_EMAILS="owner@example.com"

# Firebase web configuration. These values are public identifiers; protect access with Firebase Auth and Firestore security rules.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
